{
    "name": "caret-tui",
    "version": "1.1.0",
    "description": "A lightweight and elegant React UI Kit for modern terminals.",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./themes": {
            "import": {
                "types": "./dist/themes.d.ts",
                "default": "./dist/themes.js"
            },
            "require": {
                "types": "./dist/themes.d.cts",
                "default": "./dist/themes.cjs"
            }
        }
    },
    "bin": {
        "caret-tui": "./dist/cli/index.js"
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "dev": "tsx src/examples/demo.tsx",
        "build": "tsup",
        "prepublishOnly": "npm run build",
        "test": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "terminal",
        "tui",
        "ink",
        "react",
        "cli",
        "ui-kit",
        "components"
    ],
    "license": "MIT",
    "peerDependencies": {
        "ink": "^5.0.0",
        "react": "^18.0.0"
    },
    "dependencies": {
        "chalk": "^5.3.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "@types/react": "^18.2.0",
        "ink": "^5.1.0",
        "react": "^18.2.0",
        "tsup": "^8.0.2",
        "tsx": "^4.7.1",
        "typescript": "^5.3.3",
        "vitest": "^1.3.1"
    }
}